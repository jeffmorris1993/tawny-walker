# Copy to .env.local and fill in.
# Get these values from your Supabase project: Settings → API.
# When unset, the app falls back to bundled mock data so the UI still works.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: if set, signin requires both fields to match. Otherwise any
# non-empty credentials let the user into /admin (demo mode).
VITE_ADMIN_EMAIL=
VITE_ADMIN_PASSWORD=
