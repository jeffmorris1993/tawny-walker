# Copy to .env.local and fill in.
# Get these values from your Supabase project: Settings → API.
# Admin sign-in goes through Supabase Auth — create a user under
# Authentication → Users in the dashboard.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Public site origin (no trailing slash). Used by the runtime SEO component
# and by scripts/build-seo.mjs to emit canonical/OG/sitemap URLs and the
# llms.txt manifest. Placeholder for now — swap in the real domain once
# it's live. If unset, the build falls back to https://example.com so the
# pipeline still succeeds.
VITE_SITE_URL=
